    "#| echo: False\n",
    "#| output: True\n",
    "#| warning: False\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "th=np.linspace(0,2*np.pi,100)\n",
    "r=np.linspace(0,1,100)\n",
    "\n",
    "def ff(c,a):\n",
    "  return r**4-2*c**(2)*r**(2)*np.cos(2*th)+c**4-a**4\n",
    "\n",
    "\n",
    "for c in range(3):\n",
    "  for a in range(3):\n",
    "    plt.polar(th,r,ff(c,a),label=f\"(a,b)=({a},{c})\")\n",
    "\n",
    "plt.title('Cassini oval in polar axes')\n",
    "plt.show()"
   ]
  },
