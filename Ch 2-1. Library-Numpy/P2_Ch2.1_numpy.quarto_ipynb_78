    "#| echo: True\n",
    "#| warning: False\n",
    "import numpy as np\n",
    "\n",
    "a=np.zeros((3,5),dtype=int)\n",
    "\n",
    "for i in range(3):\n",
    " for j in range(5):\n",
    "  a[i][j]=5*i+j+1\n",
    "print(a)\n",
    "\n",
    "b=np.arange(1,16).reshape(3,5)\n",
    "print(b)\n",
    "\n",
    "print('0행3열',b[0][3])"
