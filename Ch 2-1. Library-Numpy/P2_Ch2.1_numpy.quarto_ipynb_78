    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "x1=np.linspace(0,2*np.pi,5)\n",
    "x2=np.linspace(0,2*np.pi,10)\n",
    "x3=np.linspace(0,2*np.pi,100)\n",
    "\n",
    "plt.plot(x1,np.sin(x1),label='5p')\n",
    "plt.plot(x2,np.sin(x2),label='10p')\n",
    "plt.plot(x3,np.sin(x3),label='100p')\n",
    "plt.legend()\n",
    "plt.title(\"sine graph\")"
