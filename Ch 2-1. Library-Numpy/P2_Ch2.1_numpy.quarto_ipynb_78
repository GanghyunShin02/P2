   "source": [
    "#| echo: False\n",
    "#| warning: False\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "a=np.zeros((4,4),dtype=object)\n",
    "\n",
    "for i in range(4):\n",
    "  for j in range(4):\n",
    "    if i==0 and j==0 : a[i][j]='*'\n",
    "    elif j==0: a[i][j]='행'\n",
    "    elif i==0: a[i][j]='열'\n",
    "    else: a[i][j]=3*(i-1)+j\n",
    "\n",
    "print(a)"
   ]
